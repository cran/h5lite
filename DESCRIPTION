Package: h5lite
Title: Simplified 'HDF5' Interface
Version: 2.1.1.0
Authors@R: c(
    person(
      "Daniel P.", "Smith",
      email   = "dansmith01@gmail.com",
      role    = c("aut", "cre"),
      comment = c(ORCID = "0000-0002-2479-2044")),
    person(
